{
  "name": "kedro-import-test-react-app",
  "description": "Test installing and importing the Kedro-Viz JS package into another React App",
  "main": "index.js",
  "scripts": {
    "start": "webpack-dev-server",
    "test": "jest --watch",
    "test:ci": "jest"
  },
  "jest": {
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(css|less|scss)$": "<rootDir>/__mocks__/styleMock.js",
      "^\\./graph-worker\\.js$": "<rootDir>/__mocks__/inline-worker-mock.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!d3|d3-array|internmap|delaunator|robust-predicates)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testEnvironment": "jest-environment-jsdom-global"
  },
  "dependencies": {
    "@quantumblack/kedro-viz": "file:kedro-viz.tgz",
    "react": "^18.2.0",
    "react-dev-utils": "^12.0.1",
    "react-dom": "^18.2.0",
    "react-router": "^6.30.3",
    "react-router-dom": "^6.30.3"
  },
  "devDependencies": {
    "@babel/core": "^7.10.5",
    "@babel/preset-env": "^7.10.4",
    "@babel/preset-react": "^7.10.4",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^11.2.7",
    "babel-loader": "^8.1.0",
    "clean-webpack-plugin": "^3.0.0",
    "css-loader": "^4.0.0",
    "html-webpack-plugin": "^4.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-jsdom-global": "^4.0.0",
    "style-loader": "^1.2.1",
    "webpack": "^5.105.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "jsdom": {
      "tough-cookie": ">=5.1.1"
    },
    "react-json-view": {
      "react": "$react",
      "react-dom": "$react-dom",
      "react-json-view": "^1.21.3"
    },
    "esbuild-style-plugin": {
      "glob": "^10.5.0"
    },
    "serialize-javascript": ">=7.0.5",
    "selfsigned": {
      "node-forge": ">=1.4.0"
    },
    "ajv": ">=8.18.0",
    "brace-expansion": ">=5.0.5",
    "js-yaml": ">=4.1.1",
    "picomatch": ">=4.0.2",
    "postcss": ">=8.5.8",
    "flatted": ">=3.4.2",
    "dompurify": ">=3.3.3",
    "lodash": ">=4.18.1",
    "yaml": ">=2.8.0",
    "qs": ">=6.15.0",
    "path-to-regexp": ">=0.1.13",
    "diff": ">=5.2.2",
    "d3-color": ">=3.1.0"
  }
}
